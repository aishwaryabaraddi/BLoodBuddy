<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. Force Light theme -->
    <style name="Theme.MyApplication" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">#C62828</item>
        <item name="colorPrimaryVariant">#8E0000</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Secondary brand color. -->
        <item name="colorSecondary">#C62828</item>
        <item name="colorSecondaryVariant">#8E0000</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Status bar color. -->
        <item name="android:statusBarColor">#C62828</item>

        <!-- Fix for Spinner/Dropdown background and text color -->
        <item name="android:spinnerDropDownItemStyle">@style/CustomSpinnerDropDownItemStyle</item>
        <item name="android:spinnerItemStyle">@style/CustomSpinnerItemStyle</item>
    </style>

    <style name="CustomSpinnerItemStyle" parent="Widget.AppCompat.TextView.SpinnerItem">
        <item name="android:textColor">#212121</item>
        <item name="android:padding">12dp</item>
    </style>

    <style name="CustomSpinnerDropDownItemStyle" parent="Widget.AppCompat.DropDownItem.Spinner">
        <item name="android:background">#FFFFFF</item>
        <item name="android:textColor">#212121</item>
        <item name="android:padding">12dp</item>
    </style>

    <style name="BottomNavigationViewLabelStyle" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">12sp</item>
    </style>
</resources>